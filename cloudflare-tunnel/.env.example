# =============================================================================
# Nextcloud AIO + Cloudflare Tunnel + Caddy (ACME DNS-01 Cloudflare)
# =============================================================================
# Copy this file to .env and fill in your values before running docker compose.

# --- Domain Configuration ---
# The domain you want to use for Nextcloud (e.g., cloud.example.com)
NEXTCLOUD_DOMAIN=cloud.example.com

# --- Cloudflare Configuration ---
# Your Cloudflare Tunnel token (from Zero Trust dashboard > Networks > Tunnels)
# Create a tunnel and copy the token shown in the install connector step.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...your-tunnel-token-here

# Cloudflare API token for ACME DNS-01 challenge (for local TLS certificates via Caddy)
# Create at https://dash.cloudflare.com/profile/api-tokens with:
#   - Zone:DNS:Edit permission
#   - Zone:Zone:Read permission
#   - Scoped to your zone
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# --- Nextcloud AIO Ports ---
# Port AIO's Apache container listens on (do not change unless you know what you are doing)
APACHE_PORT=11000

# --- Talk / TURN Server ---
# The built-in TURN server does NOT work behind Cloudflare Tunnel.
# You must use an external TURN server for Nextcloud Talk video/audio calls.
# Free public TURN servers or your own coturn instance can be used.
# Configure these in Nextcloud Admin > Talk settings after installation.
#
# Example using a self-hosted coturn (optional - configure in Nextcloud admin UI):
# TALK_TURN_SERVER=turn:turn.example.com:3478
# TALK_TURN_SECRET=your-turn-secret

# --- Nextcloud Data Directory (optional) ---
# Uncomment and set to store Nextcloud data on a specific host path
# NEXTCLOUD_DATADIR=/mnt/ncdata

# --- Upload Limits ---
# Cloudflare free plan limits uploads to 100 MB without chunking.
# Adjust Nextcloud upload limit (logged-in users use chunking and are not affected)
# NEXTCLOUD_UPLOAD_LIMIT=16G

# --- Timezone ---
TZ=UTC
